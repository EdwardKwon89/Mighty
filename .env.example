# ==========================================
# Mighty Prime Environment Variables Template
# ==========================================

# [Database] - For packages/database
# Supabase -> Settings -> Database -> Connection string (Transaction Mode 추천)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true"

# [Backend Server] - For apps/server
# Render -> Dashboard -> Environment
PORT=4000
JWT_SECRET="your-very-secure-secret-key-change-this"
FRONTEND_URL="https://your-app.vercel.app"

# [Frontend Client] - For apps/web
# Vercel -> Project Settings -> Environment Variables
NEXT_PUBLIC_SOCKET_URL="https://your-backend.onrender.com"
